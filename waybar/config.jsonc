// -*- mode: jsonc -*-
{
"layer": "top",
"position": "top",
"spacing": 0,  
"modules-left": [
    "hyprland/workspaces",
    "group/sysinfo",
    "tray",
    "cava"
],
"modules-center": [
    "clock",
    "hyprland/window",
    "mpris"
],
"modules-right": [
    //"privacy",
    "group/sysctrls"
],  
"hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "warp-on-scroll": false,
      "format": "{name}",
      "format-icons": {
        "1": "1",
        "2": "2",
        "3": "3",
        "4": "4",
        "focused": "´ćĺ",
        "default": "´äĹ"
      }
},
"group/sysinfo": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature",
      "disk"
    ],
  "drawer": {
    "transition-duration": 300,
    "transition-left-to-right": true,
    "children-class": "sysinfo",
    "click-to-reveal": false
  }
},
"cpu": {
  "format": "{usage}% ´őŤ",
  "tooltip": false,
  "on-click": "hyprctl dispatch -- exec '[float; size 80% 80%; center 1] ghostty -e btop'"
},
"memory": {
  "format": "{used:0.1f}G/{total:0.1f}G ´âë",
  "tooltip": true
},
"temperature": {
    "thermal-zone": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["´Łź", "´őë", "´Łę"]
},
"disk": {
  "format": "{used}/{total} ´éá",
  "path": "/",
  "tooltip": true
},  
"tray": {
    "spacing": 7
},
"cava": {
      "hide_on_silence": true,
      "sleep_timer": 3,
      "autosens": 1,
      "bar_delimiter": 0,
      "bars": 10,
      "format-icons": [
        "<span foreground='#ffffff'>Ôľü</span>",
        "<span foreground='#ffffff'>Ôľé</span>",
        "<span foreground='#ffffff'>Ôľâ</span>",
        "<span foreground='#ffffff'>Ôľä</span>",
        "<span foreground='#ffffff'>Ôľů</span>",
        "<span foreground='#ffffff'>Ôľć</span>",
        "<span foreground='#ffffff'>Ôľç</span>",
        "<span foreground='#ffffff'>Ôľł</span>"
      ],
      "framerate": 60,
      "higher_cutoff_freq": 10000,
      "input_delay": 2,
      "lower_cutoff_freq": 50,
      "method": "pipewire",
      "monstercat": false,
      "reverse": false,
      "source": "auto",
      "stereo": true,
      "waves": false
},
"clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}",
      "format": "{:%I:%M %p}"
},
"hyprland/window": {
      "format": "{} "
},
"mpris": {
  "format": "{player_icon} {title} - {artist} ´Çą",
  "format-paused": "{status_icon} {title} - {artist} ´Çą",
  "player-icons": { 
      "default": "´üő",
      "mpv": "­čÄÁ"
  },
  "status-icons": {
      "paused": "´üî"
  },
  // "ignored-players": ["firefox"]
  "max-length": 800,
  "interval": 1
},
"group/sysctrls": {
    "orientation": "inherit",
    "modules": [
        "custom/power",
        "network",
        "backlight",
        "pulseaudio",
        "battery"
    ],
    "drawer": {
          "transition-duration": 300,
          "transition-left-to-right": false,
          "children-class": "drawer-child",
          "click-to-reveal": false
    }
},
"custom/power": {
    "format": "  ´ÇĹ",
    "icon-size": 30,
    "tooltip": false,
    "on-click": "kitty wlogout --protocol layer-shell"
},
"network": {
    "format-wifi": "({signalStrength}%) ´çź",
    "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
    "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
    "format-linked": "{ifname} (No IP) ´×ľ",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
},
"backlight": {
      "format": "{percent}% {icon}",
      "format-icons": ["\uE3D3"]
},  
"pulseaudio": {
    "scroll-step": 0.5,
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "0% ´Üę",
    "format-icons": {
        "headphone": "´Çą",
        "hands-free": "´ľÉ",
        "headset": "´ľÉ",
        "phone": "´éĽ",
        "portable": "´éĽ",
        "car": "´ć╣",
        "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
      },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
},
"battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{capacity}% {icon}",
      "format-full": "{capacity}% {icon}",
      "format-charging": "{capacity}% ´Śž",
      "format-plugged": "{capacity}% ´çŽ",
      "format-alt": "{time} {icon}",
      "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
}
}



  
